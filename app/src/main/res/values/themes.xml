<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.FlareClient" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_end</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceNavigationBarContrast" tools:ignore="NewApi">false</item>
        <item name="android:enforceStatusBarContrast" tools:ignore="NewApi">false</item>
        <item name="android:fontFamily">@font/geologica_regular</item>
        <item name="fontFamily">@font/geologica_regular</item>
        <item name="android:listDivider">@drawable/menu_divider</item>
        <item name="materialSwitchStyle">@style/Widget.Flare.MaterialSwitch</item>
        <item name="android:popupWindowStyle">@style/Widget.Flare.PopupWindow</item>
    </style>

    <style name="Widget.Flare.PopupWindow" parent="@android:style/Widget.PopupWindow">
        <item name="android:popupAnimationStyle">@style/Animation.Flare.PopupNone</item>
    </style>

    <style name="Animation.Flare.PopupNone" parent="@android:style/Animation">
        <item name="android:windowEnterAnimation">@null</item>
        <item name="android:windowExitAnimation">@null</item>
    </style>

    <style name="Widget.Flare.MaterialSwitch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="android:minWidth">52dp</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:scaleX">0.82</item>
        <item name="android:scaleY">0.82</item>
        <item name="android:transformPivotX">52dp</item>
        <item name="android:transformPivotY">16dp</item>
        <item name="thumbIcon">@drawable/bg_switch_thumb_glass</item>
        <item name="thumbColor">@android:color/transparent</item>
        <item name="thumbIconTint">@null</item>
        <item name="trackDecoration">@drawable/bg_switch_track_glass</item>
        <item name="trackDecorationTint">@null</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

</resources>
