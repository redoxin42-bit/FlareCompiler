<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.FlareApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/liquidglass_start</item>
        <item name="colorPrimaryVariant">@color/liquidglass_end</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/button_start</item>
        <item name="colorSecondaryVariant">@color/button_end</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Optional: Window background to ensure full-screen gradient if not set on root layout -->
        <item name="android:windowBackground">@drawable/gradient_liquidglass_bg</item>
    </style>
</resources>